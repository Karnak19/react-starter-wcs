{
  "env": {
    "commonjs": true,
    "es2021": true,
    "node": true
  },
  "extends": ["airbnb-base", "plugin:prettier/recommended"],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "prettier/prettier": ["error", {}, { "usePrettierrc": true }],
    "no-use-before-define": ["error", { "functions": false }],
    "no-console": "off"
  }
}
